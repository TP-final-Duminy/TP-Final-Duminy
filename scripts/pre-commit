#!/bin/bash

# Définition des couleurs pour l'interface terminal
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Démarrage des vérifications de sécurité Pre-commit (Shift Left)...${NC}"

# Récupération de la liste des fichiers qui vont être commités (staged files)
STAGED_FILES=$(git diff --cached --name-only)

# S'il n'y a pas de fichiers, on sort sans erreur
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# -------------------------------------------------------------------------
# ÉTAPE 1 : Contrôle de structure strict (Interception des extensions)
# -------------------------------------------------------------------------
for FILE in $STAGED_FILES; do
  # Vérifie si le fichier se termine par .env, .pem ou .key
  if [[ "$FILE" == *".env" || "$FILE" == *".pem" || "$FILE" == *".key" ]]; then
    echo -e "${RED}Sécurité : Tentative de commit d'un fichier de configuration ou d'une clé en clair. Opération annulée.${NC}"
    exit 1
  fi
done

# -------------------------------------------------------------------------
# ÉTAPE 2 : Validation des workflows GitHub Actions avec actionlint
# -------------------------------------------------------------------------
echo "Vérification des workflows (.github/workflows) avec actionlint..."
if command -v actionlint >/dev/null 2>&1; then
  # On ne lance actionlint que sur les workflows
  actionlint .github/workflows/*
  if [ $? -ne 0 ]; then
    echo -e "${RED}Erreur : actionlint a détecté des problèmes dans vos workflows.${NC}"
    exit 1
  fi
else
  echo -e "${RED}Erreur : L'outil 'actionlint' n'est pas installé sur votre système.${NC}"
  echo "Veuillez l'installer pour continuer le commit."
  exit 1
fi

# -------------------------------------------------------------------------
# ÉTAPE 3 : Scan hermétique des secrets avec gitleaks
# -------------------------------------------------------------------------
echo "Vérification des secrets avec gitleaks..."
if command -v gitleaks >/dev/null 2>&1; then
  # L'option --staged limite le scan aux modifications prêtes à être commitées
  gitleaks protect -v --staged
  if [ $? -ne 0 ]; then
    echo -e "${RED}Erreur critique : gitleaks a détecté un secret dans vos modifications ! Commit avorté.${NC}"
    exit 1
  fi
else
  echo -e "${RED}Erreur : L'outil 'gitleaks' n'est pas installé sur votre système.${NC}"
  echo "Veuillez l'installer pour continuer le commit."
  exit 1
fi

# Si le script arrive jusqu'ici, tout est conforme
echo -e "${GREEN}Toutes les vérifications ont réussi. Commit autorisé !${NC}"
exit 0

